{
  "openapi": "3.1.1",
  "info": {
    "title": "WebAPI | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://localhost:7093"
    },
    {
      "url": "http://localhost:5053"
    }
  ],
  "paths": {
    "/api/ItemDisk/{id}": {
      "get": {
        "tags": [
          "ItemDisk"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Notebooks": {
      "get": {
        "tags": [
          "Notebooks"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "ItemDisk"
    },
    {
      "name": "Notebooks"
    }
  ]
}